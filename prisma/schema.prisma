// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

model Admin {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  password  String
  role      Role       @default(ADMIN)
  createdAt DateTime   @default(now())
  logs      AdminLog[]
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  adminId   Int?
  username  String
  action    String   // LOGIN_SUCCESS, LOGIN_FAILED, LOGOUT
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id])
}

model ApiErrorLog {
  id          Int      @id @default(autoincrement())
  route       String   // e.g. "/api/news"
  method      String   // GET, POST, PUT, DELETE
  errorMessage String  // error message or stack trace
  userAgent   String?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([route])
}

model Hero {
  id          Int      @id @default(autoincrement())
  page        String   @default("home")
  title       String
  subtitle    String?
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model About {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String?
  content     String?
  vision      String?
  mission     String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id            Int      @id @default(autoincrement())
  slug          String?  @unique
  title         String
  description   String
  category      String   @default("Lainnya")
  location      String?
  mapsUrl       String?
  lat           Float?
  lng           Float?
  client        String?
  imageUrl      String?
  galleryImages String[]
  completedDate String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model News {
  id            Int        @id @default(autoincrement())
  slug          String     @unique
  title         String
  excerpt       String?
  content       String
  imageUrl      String?
  galleryImages String[]
  category      String?
  tags          String[]
  status        NewsStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Partner {
  id        Int      @id @default(autoincrement())
  name      String?
  logoUrl   String?
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        Int      @id @default(autoincrement())
  label     String
  value     String
  icon      String?
  type      String   @default("general")
  createdAt DateTime @default(now())
}

model Statistic {
  id        Int      @id @default(autoincrement())
  label     String
  value     Int
  icon      String?
  createdAt DateTime @default(now())
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  label     String?
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageContent {
  id        Int      @id @default(autoincrement())
  pageName  String
  title     String
  subtitle  String?
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UniqueVisitor {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  lastVisit DateTime
}

model VisitStats {
  id             Int @id @default(autoincrement())
  totalVisits    Int
  uniqueVisitors Int
}

model ChatbotEvaluation {
  id        Int      @id @default(autoincrement())
  type      String   // "emoji_rating" or "negative_suggestion"
  detail    String   // the emoji or the user's text suggestion
  ip        String?
  createdAt DateTime @default(now())
}

