// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
}

model Hero {
  id          Int      @id @default(autoincrement())
  page        String   @default("home")
  title       String
  subtitle    String?
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model About {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String?
  content     String?
  vision      String?
  mission     String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  category      String   @default("Lainnya")
  location      String?
  client        String?
  imageUrl      String?
  completedDate String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model News {
  id          Int        @id @default(autoincrement())
  slug        String     @unique
  title       String
  excerpt     String?
  content     String
  imageUrl    String?
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Partner {
  id        Int      @id @default(autoincrement())
  name      String?
  logoUrl   String?
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        Int      @id @default(autoincrement())
  label     String
  value     String
  icon      String?
  type      String   @default("general")
  createdAt DateTime @default(now())
}

model Statistic {
  id        Int      @id @default(autoincrement())
  label     String
  value     Int
  icon      String?
  createdAt DateTime @default(now())
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  label     String?
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageContent {
  id        Int      @id @default(autoincrement())
  pageName  String
  title     String
  subtitle  String?
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UniqueVisitor {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  lastVisit DateTime
}

model VisitStats {
  id             Int @id @default(autoincrement())
  totalVisits    Int
  uniqueVisitors Int
}